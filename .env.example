# Supabase – Projekt-URL und anonymer Public Key
# Zu finden unter: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# Supabase Service Role Key (NUR für Seed-Skripte, NIEMALS im Frontend verwenden!)
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key-hier

# UUID des Supabase-Users, dem die Seed-Daten zugewiesen werden
SEED_USER_ID=deine-user-uuid-hier

# Datenbankschema: 'teamradar-dev' lokal, 'teamradar-test' Vercel Preview, 'teamradar-prod' Vercel Production
NEXT_PUBLIC_DB_SCHEMA=teamradar-dev

# External Apps
NEXT_PUBLIC_AWAY_URL=http://localhost:3001
NEXT_PUBLIC_TRACE_URL=http://localhost:3002
